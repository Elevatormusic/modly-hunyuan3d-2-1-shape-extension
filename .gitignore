# Python virtual environment — Modly builds this from setup.py (Repair / Install
# from GitHub). It's ~8 GB and machine-specific; never commit it.
venv/
.venv/

# Python caches & native/build artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
*.so
*.pyd

# ...but the committed prebuilt native modules are part of the feature, not
# build cruft. These negations MUST stay after the *.pyd rule above (order
# matters in .gitignore) or the artifacts silently vanish from the repo.
!prebuilt/**/*.pyd
!prebuilt/**/*.whl

# Modly local-link marker (points at a machine-specific path)
.modly-local

# Internal design docs / specs / plans / drafts — kept local, never published
private/

# BPT neural-retopo sub-venv + weights (provisioned lazily on first use, multi-GB)
bpt_runner/venv/
bpt_runner/weights/

# OS / editor cruft
.DS_Store
Thumbs.db
